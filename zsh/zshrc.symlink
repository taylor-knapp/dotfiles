# Profiling toggle: run `ZPROF=1 zsh -i -c exit` to see startup breakdown.
# zsh/zprof is a built-in module that instruments every sourced file and function call.
[[ -n "$ZPROF" ]] && zmodload zsh/zprof

# Turn off zsh's annoying auto-correct feature.
setopt nocorrectall;

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# shortcut to this dotfiles path is $DOTFILES
export DOTFILES=$HOME/.dotfiles

# your project folder that we can `c [tab]` to
export PROJECTS=~/code

# Stash your environment variables in ~/.localrc. This means they'll stay out
# of your main dotfiles repository (which may be public, like this one), but
# you'll have access to them in your scripts.
if [[ -a ~/.localrc ]]
then
  source ~/.localrc
fi

# all of our zsh files
typeset -U config_files
config_files=($DOTFILES/**/*.zsh)

# Ensure PATH only contains unique entries
typeset -U PATH

# load the path files
for file in ${(M)config_files:#*/path.zsh}
do
  source $file
done

# Source zsh/oh-my-zsh.zsh first — it loads zsh-defer which other topic files
# (e.g. iterm/) depend on. Without this, alphabetical glob order would source
# iterm/ before zsh/, and zsh-defer calls would fail.
source $DOTFILES/zsh/oh-my-zsh.zsh

# load everything but the path, completion, and already-sourced oh-my-zsh files
for file in ${${${config_files:#*/path.zsh}:#*/completion.zsh}:#*/oh-my-zsh.zsh}
do
  source $file
done

# ---------------------------------------------------------------------------
# compinit with 24-hour cache
# ---------------------------------------------------------------------------
# compinit scans $fpath and rebuilds the completion dump (~/.zcompdump).
# The security audit + full scan adds ~80ms. We skip it (`-C` flag) unless
# the dump file is older than 24 hours, at which point we do a full rebuild.
# `-C` means "use cached dump without security checks or fpath re-scan."
autoload -Uz compinit
local -a stale_dump=(${ZDOTDIR:-$HOME}/.zcompdump(N.mh+24))
if (( ${#stale_dump} )); then
  compinit        # dump is stale (>24h old) — full rebuild
else
  compinit -C     # dump is fresh — skip security audit and fpath scan
fi

# load every completion after autocomplete loads
for file in ${(M)config_files:#*/completion.zsh}
do
  source $file
done

unset config_files

# ---------------------------------------------------------------------------
# Compile zcompdump in background for faster loading
# ---------------------------------------------------------------------------
# zcompile converts the plain-text dump into a binary .zwc file that zsh can
# mmap directly, shaving ~10-20ms off future compinit loads.
# The `&!` disowns the subshell so it doesn't block startup or show in `jobs`.
{
  zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
  if [[ -s "$zcompdump" && (! -s "${zcompdump}.zwc" || "$zcompdump" -nt "${zcompdump}.zwc") ]]; then
    zcompile "$zcompdump"
  fi
} &!

# Zsh syntax highlighting must be loaded after all widgets have been loaded.
# Deferred with zsh-defer so it loads after the first prompt is drawn (~50ms saved).
# https://github.com/zsh-users/zsh-syntax-highlighting
zsh-defer source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Better history
# Credits to https://coderwall.com/p/jpj_6q/zsh-better-history-searching-with-arrow-keys
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search # Up
bindkey "^[[B" down-line-or-beginning-search # Down

# Use ctrl+u to delete from cursor to the start of the line, instead of the entire line
# Credits to https://stackoverflow.com/a/44847265/9778071
bindkey \^U backward-kill-line

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/taylorknapp/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/taylorknapp/google-cloud-sdk/path.zsh.inc'; fi

# gcloud shell completion — deferred because it sources a large file that's
# only needed once you start typing `gcloud <tab>`.
zsh-defer -c '[[ -f /Users/taylorknapp/google-cloud-sdk/completion.zsh.inc ]] && source /Users/taylorknapp/google-cloud-sdk/completion.zsh.inc'

# This sets the default editor for kubectl to neovim.
export KUBE_EDITOR="nvim"

# Set the zscaler cert so Claude Code can fetch as expected.
export NODE_EXTRA_CA_CERTS="$HOME/.certs/zscaler-root-ca.pem"

# pnpm
export PNPM_HOME="/Users/taylorknapp/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# Print profiling output if ZPROF was set (see top of file)
[[ -n "$ZPROF" ]] && zprof