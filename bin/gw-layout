#!/usr/bin/env python3
"""
gw-layout — iTerm2 pane layout manager for git worktrees.

Uses iTerm2's Python API via direct WebSocket connection for fast,
reliable pane management without AppleScript overhead.

Usage:
  gw-layout <wt_dir> [tool ...]

Tools: cl, nvim, cli (positional, no dashes)

Layout topologies:
  1 tool:            full screen
  nvim + cli:        H-split (nvim 90% top, cli 10% bottom)
  cl + cli:          H-split (cl 90% top, cli 10% bottom)
  cl + nvim:         V-split (cl 20% left, nvim 80% right)
  cl + nvim + cli:   V-split + H-split (cl 20% left, nvim 90% top-right, cli 10% bottom-right)
"""

import os
import subprocess
import sys

VENV_DIR = os.path.expanduser("~/.local/venvs/gw-layout")
VENV_PYTHON = os.path.join(VENV_DIR, "bin", "python3")


def ensure_venv():
    """Bootstrap the venv and install iterm2 if needed, then re-exec."""
    if sys.prefix != sys.base_prefix:
        # Already running inside a venv
        return

    if not os.path.isfile(VENV_PYTHON):
        print("gw-layout: creating venv and installing iterm2 package...", file=sys.stderr)
        subprocess.check_call([sys.executable, "-m", "venv", VENV_DIR])
        subprocess.check_call([VENV_PYTHON, "-m", "pip", "install", "-q", "iterm2"])

    # Re-exec under the venv python
    os.execv(VENV_PYTHON, [VENV_PYTHON] + sys.argv)


ensure_venv()

import asyncio

# --- Layout constants ---
VSPLIT_LEFT = 0.20    # cl width in V-split layouts
HSPLIT_TOP  = 0.90    # main pane height in H-split layouts


def parse_args():
    if len(sys.argv) < 2:
        print("Usage: gw-layout <wt_dir> [tool ...]", file=sys.stderr)
        sys.exit(1)
    wt_dir = sys.argv[1]
    tools = set(sys.argv[2:])
    return wt_dir, tools


def pane_command(name, wt_dir):
    if name == "cl":
        return f"cd {_quote(wt_dir)} && clear && cl"
    elif name == "nvim":
        return f"cd {_quote(wt_dir)} && nvim ."
    elif name == "cli":
        return f"cd {_quote(wt_dir)} && clear"
    return ""


def _quote(s):
    """Shell-quote a string."""
    return "'" + s.replace("'", "'\\''") + "'"


async def resize_panes(tab, total_size, sizes):
    """Set preferred_size on each session and apply the layout.

    total_size: (width, height) in cells — the full tab dimensions before splitting.
    sizes: list of (session, width_fraction, height_fraction) tuples.
    """
    import iterm2

    total_w, total_h = total_size
    for session, wf, hf in sizes:
        cols = max(1, int(total_w * wf))
        rows = max(1, int(total_h * hf))
        session.preferred_size = iterm2.util.Size(cols, rows)

    await tab.async_update_layout()


async def run_layout(wt_dir, tools):
    import iterm2

    count = len(tools)

    if count == 0:
        return

    connection = await iterm2.Connection.async_create()
    app = await iterm2.async_get_app(connection)
    window = app.current_terminal_window
    if not window:
        print("gw-layout: no iTerm2 window found", file=sys.stderr)
        return

    tab = window.current_tab

    # --- Close extra sessions ---
    current = tab.current_session
    for session in tab.sessions:
        if session.session_id != current.session_id:
            await session.async_close(force=True)

    # Re-fetch after closing
    tab = window.current_tab
    current = tab.current_session

    if count == 1:
        # Single pane — just run the command in current session
        tool = list(tools)[0]
        cmd = pane_command(tool, wt_dir)
        await current.async_send_text(cmd + "\n")
        return

    # Capture full tab dimensions before any splits
    full_size = (current.grid_size.width, current.grid_size.height)

    if count == 3:
        # 3-pane: V-split, then H-split right
        #   left = cl, top-right = nvim, bottom-right = cli
        right = await current.async_split_pane(vertical=True)
        bottom_right = await right.async_split_pane(vertical=False)

        await resize_panes(tab, full_size, [
            (current, VSPLIT_LEFT, 1.0),
            (right, 1.0 - VSPLIT_LEFT, HSPLIT_TOP),
            (bottom_right, 1.0 - VSPLIT_LEFT, 1.0 - HSPLIT_TOP),
        ])

        await current.async_send_text(pane_command("cl", wt_dir) + "\n")
        await right.async_send_text(pane_command("nvim", wt_dir) + "\n")
        await bottom_right.async_send_text(pane_command("cli", wt_dir) + "\n")

    elif count == 2:
        if "cl" in tools and "nvim" in tools:
            # V-split: left=cl, right=nvim
            right = await current.async_split_pane(vertical=True)
            await resize_panes(tab, full_size, [
                (current, VSPLIT_LEFT, 1.0),
                (right, 1.0 - VSPLIT_LEFT, 1.0),
            ])
            await current.async_send_text(pane_command("cl", wt_dir) + "\n")
            await right.async_send_text(pane_command("nvim", wt_dir) + "\n")

        elif "cl" in tools and "cli" in tools:
            # H-split: top=cl, bottom=cli
            bottom = await current.async_split_pane(vertical=False)
            await resize_panes(tab, full_size, [
                (current, 1.0, HSPLIT_TOP),
                (bottom, 1.0, 1.0 - HSPLIT_TOP),
            ])
            await current.async_send_text(pane_command("cl", wt_dir) + "\n")
            await bottom.async_send_text(pane_command("cli", wt_dir) + "\n")

        elif "nvim" in tools and "cli" in tools:
            # H-split: top=nvim, bottom=cli
            bottom = await current.async_split_pane(vertical=False)
            await resize_panes(tab, full_size, [
                (current, 1.0, HSPLIT_TOP),
                (bottom, 1.0, 1.0 - HSPLIT_TOP),
            ])
            await current.async_send_text(pane_command("nvim", wt_dir) + "\n")
            await bottom.async_send_text(pane_command("cli", wt_dir) + "\n")


def main():
    wt_dir, tools = parse_args()
    asyncio.run(run_layout(wt_dir, tools))


if __name__ == "__main__":
    main()
