#!/bin/zsh
#
# gw — Git Worktree manager with iTerm pane layout
#
# Usage:
#   gw                           # list existing worktrees
#   gw <name>                    # create/navigate worktree, branch = <name>
#   gw <name> <branch>           # create/navigate worktree, checkout <branch>
#   gw <name> cl nvim            # open with claude + nvim panes
#   gw <name> <branch> cli       # checkout branch, open with cli pane
#   gw root                      # cd to main worktree root
#   gw root cl nvim              # cd to root + open with tools
#
# Tools: cl (or claude), nvim, cli — positional, any order

local -a tools
local name="" branch=""
local -A known_tools=([cl]=1 [claude]=1 [cli]=1 [nvim]=1)

for arg in "$@"; do
  if (( ${+known_tools[$arg]} )); then
    [[ "$arg" == "claude" ]] && arg="cl"
    tools+=("$arg")
  elif [[ -z "$name" ]]; then
    name="$arg"
  elif [[ -z "$branch" ]]; then
    branch="$arg"
  else
    echo "gw: unexpected argument '$arg'" >&2
    return 1
  fi
done

# --- Resolve main worktree root ---
local main_root
main_root=$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')
if [[ -z "$main_root" ]]; then
  echo "gw: not a git repository" >&2
  return 1
fi

# --- No args: list worktrees ---
if [[ -z "$name" ]]; then
  git worktree list
  return 0
fi

# --- Special case: gw root ---
if [[ "$name" == "root" ]]; then
  if [[ -n "$branch" ]]; then
    echo "gw: 'root' does not accept a branch argument" >&2
    return 1
  fi
  cd "$main_root"
  if (( ${#tools} )) && (( $+commands[gw-layout] )); then
    gw-layout "$main_root" "${tools[@]}"
  fi
  return 0
fi

local wt_base="${main_root}-worktrees"
local wt_dir="$wt_base/$name"

# --- Navigate to or create worktree ---
if [[ -d "$wt_dir" ]]; then
  cd "$wt_dir"
  # Checkout branch if specified
  if [[ -n "$branch" ]]; then
    git checkout "$branch" || return 1
  fi
else
  # Confirm before creating
  echo -n "gw: worktree '$name' does not exist. Create it? [y/N] "
  read -r reply
  if [[ "$reply" != [yY] ]]; then
    return 0
  fi

  mkdir -p "$wt_base"
  if [[ -n "$branch" ]]; then
    git worktree add "$wt_dir" "$branch" || return 1
  else
    # Try existing branch first, fall back to new branch off main
    if git show-ref --verify --quiet "refs/heads/$name" 2>/dev/null || \
       git show-ref --verify --quiet "refs/remotes/origin/$name" 2>/dev/null; then
      git worktree add "$wt_dir" "$name" || return 1
    else
      git worktree add -b "$name" "$wt_dir" main || return 1
    fi
  fi
  echo "gw: created worktree at $wt_dir"
  cd "$wt_dir"
fi

# --- Symlink shared files from main worktree ---
gw-link "$wt_dir"

# --- Set up iTerm pane layout ---
if (( $+commands[gw-layout] )); then
  gw-layout "$wt_dir" "${tools[@]}"
else
  echo "gw: gw-layout not found, skipping pane layout" >&2
fi
