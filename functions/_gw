#compdef gw

_gw() {
  local main_root
  main_root=$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')

  local -a tools=(
    'cl:claude code'
    'claude:claude code (alias for cl)'
    'cli:terminal pane'
    'nvim:neovim editor'
  )

  _arguments -S \
    '1:worktree name:->worktree' \
    '*:tool or branch:->tool_or_branch' \
    && return

  case "$state" in
    worktree)
      local -a special=('root:main worktree root')
      local wt_base="${main_root}-worktrees"
      if [[ -n "$main_root" && -d "$wt_base" ]]; then
        _alternative \
          'special:special:((${special}))' \
          "worktrees:worktree:_files -W $wt_base -/"
      else
        _describe 'special' special
      fi
      ;;
    tool_or_branch)
      _alternative \
        'tools:tool:((${tools}))' \
        'branches:branch:__git_branch_names'
      ;;
  esac
}

_gw "$@"
